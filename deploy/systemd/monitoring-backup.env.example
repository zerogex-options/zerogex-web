# Config for the zerogex-web-monitoring-backup systemd service.
# Copy to monitoring-backup.env (same dir) and fill in. All keys are OPTIONAL;
# with none set, the job takes a local-only backup into BACKUP_DIR. These are
# read by `make backup-monitoring` as make variables.
#
#   sudo cp monitoring-backup.env.example monitoring-backup.env && chmod 600 monitoring-backup.env
#
# Do NOT commit monitoring-backup.env (it may name a private bucket).

# Upload each archive to S3. NOTE: monitoring.json contains client IP addresses
# and user identifiers, so use a PRIVATE bucket with SSE (and ideally
# versioning / Object Lock); see zerogex-oa/deploy/BACKUP_RESILIENCE.md.
# signups.json and mrr.json are aggregate daily counts only (no PII).
#S3_BUCKET=s3://your-bucket/zerogex/monitoring

# Where local archives are written. NOTE: if you change this, also update
# ReadWritePaths in zerogex-web-monitoring-backup.service to match.
#BACKUP_DIR=/home/ubuntu/zerogex-monitoring-backups

# Prune local archives older than N days (default 30). S3 lifecycle handles
# remote retention. The daily samples inside are append-only, so each archive
# is a full point-in-time copy of the whole history.
#BACKUP_RETENTION_DAYS=30
