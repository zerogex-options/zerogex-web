# Config for the zerogex-web-auth-backup systemd service.
# Copy to backup-auth.env (same dir) and fill in. All keys are OPTIONAL;
# with none set, the job takes a local-only, unencrypted backup into
# AUTH_BACKUP_DIR. These are read by `make backup-auth` as make variables.
#
#   sudo cp backup-auth.env.example backup-auth.env && chmod 600 backup-auth.env
#
# Do NOT commit backup-auth.env (it may name a private bucket / GPG key).

# Upload each archive to S3. The bucket MUST be private with SSE; see
# zerogex-oa/deploy/BACKUP_RESILIENCE.md for the required bucket hardening.
#S3_BUCKET=s3://your-bucket/zerogex/auth

# Encrypt the archive with GPG before it leaves the box. STRONGLY recommended:
# the archive contains password hashes and PII. The recipient key must be in
# the ubuntu user's keyring (gpg --import). If unset, rely on SSE-KMS instead.
#BACKUP_GPG_RECIPIENT=ops@zerogex.com

# Source DB. Defaults to the value in frontend/.env.local, then
# frontend/data/auth.db. Set explicitly if you want to be unambiguous.
#AUTH_DB_PATH=/var/lib/zerogex/auth.db

# Where local snapshots are written. NOTE: if you change this, also update
# ReadWritePaths in zerogex-web-auth-backup.service to match.
#AUTH_BACKUP_DIR=/home/ubuntu/zerogex-auth-backups

# Prune local archives older than N days (default 30). S3 lifecycle handles
# remote retention.
#AUTH_BACKUP_RETENTION_DAYS=30
