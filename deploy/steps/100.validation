#!/bin/bash

# ==============================================
# Step 100: Deployment Validation
# ==============================================

set -e

log "Deployment Validation"

APP_DIR="${WEB_APP_DIR:-$HOME/zerogex-web/frontend}"
APP_NAME="${WEB_PM2_NAME:-zerogex-web}"
WEB_PORT="${WEB_PORT:-3000}"
SITE_NAME="${WEB_SITE_NAME:-zerogex-web}"

# Validation tracking
TOTAL_CHECKS=0
PASSED_CHECKS=0
FAILED_CHECKS=0

# Section 1: Node.js
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "1. Node.js Environment"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    \. "$NVM_DIR/nvm.sh"
    # Pin to the same Node version steps/040.pm2 installed pm2 under, so
    # `pm2 list` resolves below. Without this we run on whatever the
    # `default` alias points at, which on hosts that had Node 18 pre-nvm
    # leaves pm2 invisible to validation (see deploy run 2026-05-08).
    nvm use 22 >/dev/null 2>&1 || true
fi

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if command -v node &> /dev/null; then
    NODE_VERSION=$(node -v)
    log "  ✓ Node.js installed: $NODE_VERSION"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Node.js not found"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Section 2: Application
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "2. Application Files"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if [ -d "$APP_DIR" ]; then
    log "  ✓ Application directory exists"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Application directory not found"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if [ -d "$APP_DIR/.next" ]; then
    log "  ✓ Production build exists"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Production build not found"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Section 3: PM2
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "3. PM2 Process Manager"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if pm2 list | grep -q "$APP_NAME"; then
    # Check if process is online (status column contains "online")
    if pm2 list | grep "$APP_NAME" | grep -q "online"; then
        log "  ✓ Application running (PM2)"
        PASSED_CHECKS=$((PASSED_CHECKS + 1))
    else
        PM2_STATUS=$(pm2 list | grep "$APP_NAME" | awk '{print $10}')
        log "  ✗ Application not online (status: $PM2_STATUS)"
        FAILED_CHECKS=$((FAILED_CHECKS + 1))
    fi
else
    log "  ✗ Application not found in PM2"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Section 4: Nginx
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "4. Nginx Configuration"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if sudo systemctl is-active --quiet nginx; then
    log "  ✓ Nginx is running"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Nginx is not running"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

NGINX_CONF="/etc/nginx/sites-enabled/$SITE_NAME"
TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if [ -f "$NGINX_CONF" ]; then
    log "  ✓ Site configuration enabled"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Site configuration not found"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Routing invariant: /api/ must terminate at the Next.js BFF, not direct
# to FastAPI. 050.nginx and 070.ssl independently template the nginx
# config, so a future change to one can easily get lost in the other
# (commit 0f1a102 fixed exactly that desync). Fail loudly if the bare
# `location /api/` block isn't proxying to WEB_PORT.
TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if [ -r "$NGINX_CONF" ]; then
    EXPECTED_PROXY="http://127.0.0.1:$WEB_PORT"
    API_PROXY=$(sudo awk '
        /^[[:space:]]*location[[:space:]]+\/api\/[[:space:]]*\{/{found=1; next}
        found && /proxy_pass/{print; exit}
    ' "$NGINX_CONF" | grep -oE 'http://[^;[:space:]]+' | head -1 | sed 's#/$##')
    if [ "$API_PROXY" = "$EXPECTED_PROXY" ]; then
        log "  ✓ /api/ routes to BFF ($API_PROXY)"
        PASSED_CHECKS=$((PASSED_CHECKS + 1))
    else
        log "  ✗ /api/ proxy_pass is '$API_PROXY', expected '$EXPECTED_PROXY'"
        log "    050.nginx and 070.ssl may have desynced. Re-run 050 then 070."
        FAILED_CHECKS=$((FAILED_CHECKS + 1))
    fi
else
    log "  ✗ Cannot read $NGINX_CONF for routing invariant check"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Section 5: Port Check
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "5. Port Connectivity"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if curl -s --max-time 5 "http://localhost:$WEB_PORT" > /dev/null 2>&1; then
    log "  ✓ Application responds on port $WEB_PORT"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Application not responding on port $WEB_PORT"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Section 5b: Authentication Configuration
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "5b. Authentication Configuration"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

ENV_FILE="$APP_DIR/.env.local"
ECOSYSTEM_FILE="$(dirname "$APP_DIR")/ecosystem.config.js"

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if [ -f "$ECOSYSTEM_FILE" ]; then
    log "  ✓ ecosystem.config.js present"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ ecosystem.config.js not found at $ECOSYSTEM_FILE"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if [ -f "$ENV_FILE" ]; then
    AUTH_FLAG=$(grep -E "^NEXT_PUBLIC_AUTH_ENABLED=" "$ENV_FILE" | tail -1 | cut -d= -f2-)
    if [ "$AUTH_FLAG" = "1" ]; then
        log "  ℹ Auth enabled (NEXT_PUBLIC_AUTH_ENABLED=1)"
        PASSED_CHECKS=$((PASSED_CHECKS + 1))

        # When auth is enabled, AUTH_DB_PATH must be absolute and writable.
        TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
        DB_PATH=$(grep -E "^AUTH_DB_PATH=" "$ENV_FILE" | tail -1 | cut -d= -f2-)
        if [ -z "$DB_PATH" ]; then
            log "  ✗ AUTH_DB_PATH is empty"
            FAILED_CHECKS=$((FAILED_CHECKS + 1))
        elif [[ "$DB_PATH" != /* ]]; then
            log "  ✗ AUTH_DB_PATH must be absolute (got: $DB_PATH)"
            FAILED_CHECKS=$((FAILED_CHECKS + 1))
        else
            DB_DIR=$(dirname "$DB_PATH")
            if [ -d "$DB_DIR" ] && [ -w "$DB_DIR" ]; then
                log "  ✓ AUTH_DB_PATH dir exists and is writable: $DB_DIR"
                PASSED_CHECKS=$((PASSED_CHECKS + 1))
            else
                log "  ✗ AUTH_DB_PATH dir missing or not writable: $DB_DIR"
                FAILED_CHECKS=$((FAILED_CHECKS + 1))
            fi
        fi

        # Warn loudly if bootstrap creds are still set — they should be removed
        # after first admin login.
        if grep -qE "^ADMIN_BOOTSTRAP_PASSWORD=.+" "$ENV_FILE"; then
            log "  ⚠ ADMIN_BOOTSTRAP_PASSWORD is still set — remove after first login"
        fi
    else
        log "  ℹ Auth dormant (NEXT_PUBLIC_AUTH_ENABLED=${AUTH_FLAG:-unset})"
        PASSED_CHECKS=$((PASSED_CHECKS + 1))
    fi
else
    log "  ✗ $ENV_FILE not found"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Section 5c: BFF process integrity — confirm the running Node child is
# on v22. node:sqlite (required by frontend/core/db.ts for the auth DB)
# is only available on Node 22+; if pm2 spawned the BFF under Node 20 the
# auth middleware fails to import, every page renders 500, but /api/*
# still returns 200 because the BFF route handlers don't touch sqlite.
# Catch this divergence here rather than in browser-side smoke tests.
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "5c. BFF Process Integrity"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
BFF_NODE_PID=""
BFF_NODE_EXE=""
# pgrep -f matches both the npm-wrapper shell (`sh -c "next start"`) and
# the actual Node process; we walk matches and pick the one whose
# /proc/PID/exe is a node binary.
for p in $(pgrep -f "next-server|next start" 2>/dev/null); do
    exe=$(sudo readlink "/proc/$p/exe" 2>/dev/null) || continue
    case "$exe" in
        */node)
            BFF_NODE_PID="$p"
            BFF_NODE_EXE="$exe"
            break
            ;;
    esac
done

if [ -z "$BFF_NODE_PID" ]; then
    log "  ✗ No Node process found for the BFF (pgrep next-server matched nothing usable)"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
elif [[ "$BFF_NODE_EXE" == */v22.*/bin/node ]]; then
    BFF_NODE_VER=$(echo "$BFF_NODE_EXE" | grep -oE 'v22\.[0-9.]+')
    log "  ✓ BFF (PID $BFF_NODE_PID) running on Node $BFF_NODE_VER"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ BFF (PID $BFF_NODE_PID) is NOT on Node 22 — exe: $BFF_NODE_EXE"
    log "    node:sqlite (required by core/db.ts) is unavailable on this Node;"
    log "    pages will 500 even if /api/* returns 200."
    log "    Confirm ecosystem.config.js has 'interpreter' set, then re-run 040.pm2."
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Section 6: Firewall
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "6. Firewall Configuration"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if sudo ufw status | grep -q "80/tcp.*ALLOW"; then
    log "  ✓ Port 80 (HTTP) open in firewall"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Port 80 not open in firewall"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
if sudo ufw status | grep -q "443/tcp.*ALLOW"; then
    log "  ✓ Port 443 (HTTPS) open in firewall"
    PASSED_CHECKS=$((PASSED_CHECKS + 1))
else
    log "  ✗ Port 443 not open in firewall"
    FAILED_CHECKS=$((FAILED_CHECKS + 1))
fi

# Final Summary
log ""
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "VALIDATION SUMMARY"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log ""
log "Total Checks: $TOTAL_CHECKS"
log "Passed: $PASSED_CHECKS"
log "Failed: $FAILED_CHECKS"
log ""

if [ "$FAILED_CHECKS" -eq 0 ]; then
    log "✓ Deployment validation PASSED!"
    log ""
    log "ZeroGEX Web is ready!"
    log ""
    log "Access your site:"
    DOMAIN=$(grep "server_name" "/etc/nginx/sites-available/$SITE_NAME" 2>/dev/null | awk '{print $2}' | sed 's/;//' | head -1)
    if [ ! -z "$DOMAIN" ]; then
        # Check if SSL certificate exists
        if [ -d "/etc/letsencrypt/live/$DOMAIN" ]; then
            log "  https://$DOMAIN"
        else
            log "  http://$DOMAIN"
        fi
    fi
    log "  http://$(curl -s ifconfig.me):80"
else
    log "✗ Deployment validation FAILED!"
    log ""
    log "Please review failed checks above."
    exit 1
fi
