#!/bin/bash

# ==============================================
# Step 030: Application Setup
# ==============================================

set -e

log "Application Setup"

# Define application directory
APP_DIR="$HOME/zerogex-web"

# Check if application directory already exists
if [ -d "$APP_DIR" ]; then
    log "  → Application directory exists, pulling latest changes..."
    cd "$APP_DIR"
    git pull
else
    log "  → Cloning repository..."
    cd "$HOME"
    
    # Prompt for git repository URL
    read -p "  Enter git repository URL: " GIT_REPO
    while [ -z "$GIT_REPO" ]; do
        echo "     ✗ Repository URL cannot be empty"
        read -p "  Enter git repository URL: " GIT_REPO
    done
    
    git clone "$GIT_REPO" zerogex-web
    cd "$APP_DIR"
fi

# Navigate to frontend directory
log "  → Navigating to frontend directory..."
cd "$APP_DIR/frontend"

# Load nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Use Node 22 (required for node:sqlite used by auth DB layer)
nvm use 22

# Install dependencies
log "  → Installing npm dependencies..."
npm install

# Clear Next.js build cache for clean build
log "  → Clearing Next.js build cache..."
rm -rf .next

# Prompt for domain name for .env.local
read -p "  Enter your domain name for API configuration (e.g., zerogex.io): " DOMAIN_NAME
while [ -z "$DOMAIN_NAME" ]; do
    echo "     ✗ Domain name cannot be empty"
    read -p "  Enter your domain name: " DOMAIN_NAME
done

# Create or update .env.local (idempotent: only writes keys that are missing)
log "  → Ensuring .env.local has required keys..."
touch .env.local
chmod 600 .env.local

ensure_env_key() {
  local key="$1"
  local value="$2"
  if ! grep -qE "^${key}=" .env.local; then
    printf '%s=%s\n' "$key" "$value" >> .env.local
    log "     + Added $key"
  else
    log "     ✓ $key already set"
  fi
}

ensure_env_key "NEXT_PUBLIC_API_URL" "https://$DOMAIN_NAME"
ensure_env_key "NEXT_PUBLIC_WS_URL" "wss://$DOMAIN_NAME/ws"
ensure_env_key "NEXT_PUBLIC_ENABLE_WEBSOCKET" "false"
ensure_env_key "NEXT_PUBLIC_ENABLE_GRAFANA" "false"
# Auth feature flag (off by default — see step 035.auth to enable).
ensure_env_key "NEXT_PUBLIC_AUTH_ENABLED" "0"
log "     ✓ .env.local configured for domain: $DOMAIN_NAME"

# Build for production
log "  → Building application for production..."
npm run build

log ""
log "Application setup complete!"
log ""
log "Summary:"
log "  ✓ Repository cloned/updated"
log "  ✓ Dependencies installed"
log "  ✓ Production build created"
log "  ✓ .env.local configured for domain: $DOMAIN_NAME"
log "  ✓ API will be proxied through nginx at /api"
log ""
