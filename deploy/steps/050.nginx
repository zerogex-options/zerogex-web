#!/bin/bash

# ==============================================
# Step 050: Nginx Reverse Proxy (HTTP bootstrap)
# ==============================================

set -euo pipefail

log "Nginx Reverse Proxy (HTTP bootstrap)"

# Config (supports independent or co-hosted deployments)
SITE_NAME="${WEB_SITE_NAME:-zerogex-web}"
WEB_PORT="${WEB_PORT:-3000}"
API_UPSTREAM="${WEB_API_UPSTREAM:-http://127.0.0.1:8000}"
DOMAIN_NAME="${WEB_DOMAIN:-}"
CONF_PATH="/etc/nginx/sites-available/${SITE_NAME}"

if [ -z "$DOMAIN_NAME" ]; then
  read -p "  Enter your web domain (e.g., app.zerogex.io): " DOMAIN_NAME
fi

while [ -z "$DOMAIN_NAME" ]; do
  echo "     ✗ Domain cannot be empty"
  read -p "  Enter your web domain: " DOMAIN_NAME
done

log "  → Site name: $SITE_NAME"
log "  → Domain: $DOMAIN_NAME"
log "  → Frontend upstream: http://127.0.0.1:$WEB_PORT"
log "  → API/WS upstream: $API_UPSTREAM"

# Detect conflicting server_name ownership across enabled sites.
log "  → Checking for conflicting server_name ownership..."
CONFLICTS=$(sudo grep -R "server_name" /etc/nginx/sites-enabled 2>/dev/null \
  | grep -E "(^|[[:space:]])${DOMAIN_NAME}([[:space:];]|$)|(^|[[:space:]])www\.${DOMAIN_NAME}([[:space:];]|$)" \
  | grep -v "/${SITE_NAME}:" || true)

if [ -n "$CONFLICTS" ]; then
  log "  ✗ Conflict detected: another enabled nginx site already serves ${DOMAIN_NAME}"
  log "    Details:"
  while IFS= read -r line; do log "      $line"; done <<< "$CONFLICTS"
  log "    Use a distinct domain/subdomain (recommended: app.* for web, api.* for API)."
  exit 1
fi

# Shared snippets used across zerogex services (safe if co-hosted)
log "  → Ensuring shared nginx snippets exist..."
if [ ! -f /etc/nginx/conf.d/zerogex-upgrade-map.conf ]; then
  sudo tee /etc/nginx/conf.d/zerogex-upgrade-map.conf > /dev/null <<'MAPEOF'
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
MAPEOF
fi

if [ ! -f /etc/nginx/conf.d/zerogex-rate-limit.conf ]; then
  sudo tee /etc/nginx/conf.d/zerogex-rate-limit.conf > /dev/null <<'LIMITEOF'
# Per-IP rate limiting for app/API endpoints
limit_req_zone $binary_remote_addr zone=zerogex_api_per_ip:10m rate=20r/s;
LIMITEOF
fi

# Proxy response cache. The same zone is also defined by zerogex-oa
# (deploy/steps/120.nginx_api). Whichever repo deploys first writes the
# snippet; the other skips. The cache directory is created unconditionally
# so the proxy_cache_path directive can always start cleanly.
sudo mkdir -p /var/cache/nginx/zerogex
sudo chown www-data:www-data /var/cache/nginx/zerogex

if [ ! -f /etc/nginx/conf.d/zerogex-cache-zone.conf ]; then
  sudo tee /etc/nginx/conf.d/zerogex-cache-zone.conf > /dev/null <<'CACHEEOF'
# Response cache for idempotent GETs. 5s TTL + use_stale + background_update
# keeps users on slightly-stale data when the upstream is slow or briefly down.
proxy_cache_path /var/cache/nginx/zerogex levels=1:2 keys_zone=zerogex_cache:10m
                 max_size=200m inactive=30s use_temp_path=off;
CACHEEOF
fi

# Write HTTP bootstrap config (TLS hardened config comes in step 070)
log "  → Writing HTTP bootstrap nginx config: $CONF_PATH"
sudo tee "$CONF_PATH" >/dev/null <<EOF_CONF
server {
    listen 80;
    listen [::]:80;
    server_name ${DOMAIN_NAME} www.${DOMAIN_NAME};

    # ACME challenge path for certbot
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Next.js Stripe webhook endpoint — kept separate because signature
    # verification needs the raw request body, so proxy_buffering must
    # be off here (and only here).
    location ^~ /api/webhooks/ {
        proxy_pass http://127.0.0.1:${WEB_PORT};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        proxy_request_buffering off;
        proxy_buffering off;

        proxy_connect_timeout 15s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # All /api/* requests now flow through the Next.js BFF, which
    # injects X-API-Key from server-only env (ZEROGEX_API_KEY) before
    # proxying to the FastAPI backend. nginx is no longer responsible
    # for authenticating any upstream call — the website carries its
    # own per-caller key, just like external API consumers do.
    #
    # This block intentionally covers /api/auth/*, /api/admin/*,
    # /api/billing/*, /api/account/* too (they are also Next.js route
    # handlers). The only /api/* path that needs a separate block is
    # /api/webhooks/* above, because Stripe signature verification
    # requires raw request bodies (proxy_buffering off).
    location /api/ {
        proxy_pass http://127.0.0.1:${WEB_PORT};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        # Sized for heavy historical queries (window_units=90) on 2-vCPU
        # box; the BFF is a thin pass-through, so most of this is the
        # FastAPI roundtrip behind it.
        proxy_connect_timeout 30s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        # Response cache. zerogex_cache zone is defined in the zerogex-oa
        # repo (deploy/steps/120.nginx_api); proxy_cache_lock collapses
        # simultaneous duplicate requests, use_stale + background_update
        # serve cached values when upstream is slow or briefly down.
        proxy_cache zerogex_cache;
        proxy_cache_methods GET;
        proxy_cache_valid 200 5s;
        proxy_cache_valid 404 1s;
        proxy_cache_key "\$request_method\$request_uri";
        proxy_cache_lock on;
        proxy_cache_lock_timeout 90s;
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
        proxy_cache_background_update on;
        add_header X-Cache-Status \$upstream_cache_status always;

        limit_req zone=zerogex_api_per_ip burst=1000 nodelay;
    }

    # WebSocket reverse proxy. Direct to FastAPI for now — disabled by
    # default in the app (NEXT_PUBLIC_ENABLE_WEBSOCKET=false). If/when
    # WS is enabled, this block will need its own auth solution since
    # browser WebSockets can't send custom headers like X-API-Key.
    location /ws {
        proxy_pass ${API_UPSTREAM}/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        proxy_connect_timeout 15s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Frontend reverse proxy
    location / {
        proxy_pass http://127.0.0.1:${WEB_PORT};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        proxy_connect_timeout 15s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
EOF_CONF

log "  → Enabling site ${SITE_NAME}"
sudo ln -sfn "$CONF_PATH" "/etc/nginx/sites-enabled/${SITE_NAME}"

log "  → Testing nginx configuration"
sudo nginx -t

log "  → Restarting nginx"
sudo systemctl restart nginx
sudo systemctl enable nginx

log ""
log "Nginx bootstrap configuration complete!"
log "Summary:"
log "  ✓ Site enabled: ${SITE_NAME}"
log "  ✓ Domain: ${DOMAIN_NAME} (and www)"
log "  ✓ /api/* → Next.js BFF on :${WEB_PORT} (key injected app-side)"
log "  ✓ /ws    → ${API_UPSTREAM} (WS disabled by default)"
log "  ✓ HTTP reverse proxy active; ACME challenge path ready"
log ""
log "Action required on this host (one-time, if not already done):"
log "  • Remove the legacy nginx X-API-Key snippet — it's no longer"
log "    referenced and the API repo's deploy will delete it anyway:"
log "        sudo rm -f /etc/nginx/conf.d/zerogex-api-key*.conf"
log "        sudo systemctl reload nginx"
log ""
log "Next step:"
log "  • Run step 070 for hardened HTTPS + auto-renew"
