# Feature flag: set to 1 to enable user authentication (login/register/OAuth).
# When 0 (default), /api/auth/* returns 404, /login and /register redirect to /,
# and all tier-gated routes are open to everyone. Auth code stays installed but dormant.
NEXT_PUBLIC_AUTH_ENABLED=0

# NYSE holiday calendar — comma-separated YYYY-MM-DD list. Drives the
# header options-events badge: surfaces upcoming market closures as their
# own entries and shifts OPEX/VIX-expiry/quarter-end/JPM-collar dates back
# to the previous business day when they land on a closed day (e.g.
# Juneteenth on the 3rd Friday of June pushes Quad Witching to Thursday).
# Must be NEXT_PUBLIC_-prefixed so the value reaches the browser bundle.
# Unset ⇒ no holiday awareness (legacy behavior).
NEXT_PUBLIC_NYSE_HOLIDAYS=

# ==============================================================================
# Backend API access. The browser only ever hits same-origin /api/* URLs;
# Next.js route handlers under app/api/{gex,flow,market,signals,option,
# max-pain,technicals,health}/ proxy them to ZEROGEX_API_BASE_URL with an
# `Authorization: Bearer <token>` header attached on the server. The token
# never reaches the browser.
# ==============================================================================

# Server-only per-user token for this website (one row in the backend's
# api_keys table, e.g. labeled `website-prod` or `zerogex-web-bff`). Required
# in production. NEVER prefix this with NEXT_PUBLIC_ — that would inline it
# into the browser bundle.
# Legacy name `ZEROGEX_API_KEY` is still read as a fallback for a single
# release; remove from your env once you've migrated to ZEROGEX_API_TOKEN.
ZEROGEX_API_TOKEN=

# Backend the BFF proxies to. Defaults to http://127.0.0.1:8000 because
# FastAPI is colocated with the website on production. Override locally
# if you run the backend somewhere else.
ZEROGEX_API_BASE_URL=http://127.0.0.1:8000

# Server-only shared secret for end-user attribution. When set, every
# authenticated server→ZeroGEX request also carries a short-lived HS256
# JWT (X-End-User-Token) naming the logged-in user, so the backend can
# attribute the shared-key call to a specific human (audit logs / rate
# limiting). Like ZEROGEX_API_TOKEN: NEVER prefix with NEXT_PUBLIC_.
#
# Must be byte-identical to the API host's END_USER_TOKEN_SECRET.
# Generate one with:  python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
#
# Unset ⇒ attribution disabled; requests are caller-only (exactly as
# before). Minting is fail-safe — if it ever errors the request still
# goes out with the Bearer key. Required in production (a missing value
# logs a loud one-time server error).
ZEROGEX_END_USER_TOKEN_SECRET=

# Client-side base URL for browser fetches. Leave empty in production so
# calls are same-origin (/api/gex/summary, etc.) and flow through the BFF
# above. For local dev where you'd rather hit the backend directly,
# bypassing the BFF and the API key, set to http://localhost:8000.
NEXT_PUBLIC_API_URL=

# ==============================================================================
# The variables below are only required when NEXT_PUBLIC_AUTH_ENABLED=1.
# ==============================================================================

# Authentication database location (SQLite). Use an absolute path in production
# so PM2 cwd changes don't relocate the DB file.
AUTH_DB_PATH=/var/lib/zerogex/auth.db
# Session persistence controls (defaults: 14 days TTL, rotate every 24 hours).
AUTH_SESSION_TTL_SECONDS=1209600
AUTH_SESSION_ROTATE_AFTER_SECONDS=86400
# Password reset link lifetime in seconds (default: 1800 = 30 minutes).
AUTH_PASSWORD_RESET_TTL_SECONDS=1800

# Optional one-time admin bootstrap (recommended for first deployment only).
# After first successful login, remove these from the environment and restart.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMeNow-StrongPassword

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/oauth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=https://your-domain.com/api/auth/oauth/apple/callback

# Stripe (sandbox/test keys for development; live keys in production).
# STRIPE_SECRET_KEY: from https://dashboard.stripe.com/test/apikeys
# STRIPE_WEBHOOK_SECRET: from the webhook endpoint dashboard or `stripe listen`.
#
# Webhook events the app requires (Dashboard -> Developers -> Webhooks ->
# your endpoint -> "Listen to events"):
#   Subscription lifecycle:
#     - checkout.session.completed
#     - customer.subscription.created / .updated / .deleted / .resumed / .paused
#     - invoice.payment_failed
#   Creator Partner Program (Phase 3 commission accrual):
#     - invoice.paid                    (accrue commission on every paid invoice)
#     - charge.refunded                 (reverse commission on refund)
#     - charge.dispute.created          (reverse commission on chargeback)
# Missing events are a silent failure — commissions never accrue and you
# won't know until a partner asks why they weren't paid. Double-check
# subscribed events after any Stripe endpoint rotation.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs per tier (one Product per tier in the Stripe dashboard).
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# --- Limited-time public promo (auto-applied to every checkout) -----------
# Time-boxed introductory pricing for the public /pricing flow. While
# PROMO_END_AT is in the future AND the matching coupon env is set, the
# coupon is silently attached to every checkout for that (tier, cadence)
# pair. The /pricing page surfaces a "Limited Time Offer" banner and shows
# the promo prices in big, bold type whenever any cadence has a live offer.
#
# Active offer (target rates):
#   basic monthly: $19/mo  (orig $39) — first 6 months
#   pro   monthly: $29/mo  (orig $59) — first 6 months
#   basic annual:  $150/yr (orig $199) — first year
#   pro   annual:  $229/yr (orig $299) — first year
#
# After the offer window ends the subscription renews at the standard rack
# rate above automatically — Stripe drops the coupon when its duration is
# exhausted, no code change required.
#
# Coupon configuration (create one per row in the Stripe dashboard):
#   _BASIC_MONTHLY  amount_off=2000 (cents) currency=usd duration=repeating duration_in_months=6
#   _PRO_MONTHLY    amount_off=3000 (cents) currency=usd duration=repeating duration_in_months=6
#   _BASIC_ANNUAL   amount_off=4900 (cents) currency=usd duration=once
#   _PRO_ANNUAL     amount_off=7000 (cents) currency=usd duration=once
# Belt-and-braces: in Stripe, restrict each coupon to "Applies to → specific
# products" so the monthly coupons can never land on an annual invoice (and
# vice versa) even if the env vars get crossed.
PROMO_END_AT=
STRIPE_COUPON_PROMO_BASIC_MONTHLY=
STRIPE_COUPON_PROMO_PRO_MONTHLY=
STRIPE_COUPON_PROMO_BASIC_ANNUAL=
STRIPE_COUPON_PROMO_PRO_ANNUAL=

# --- Automated win-back coupon (churned-member reactivation) --------------
# Standing (NOT time-boxed) discount applied at checkout when a churned member
# returns through the ?winback=1 link in the ~1-month win-back email
# (scripts/send-winback.mts). Unlike the public promo above, this is per-user:
# the checkout route only attaches it when the account is actually churned
# (subscription_lapsed=1) AND has a win-back email on record, so a random
# ?winback=1 on a never-churned account gets nothing. One coupon per (tier,
# cadence), same shape as the promo coupons. Leave every var unset to disable
# the automated path — the win-back email then falls back to its evergreen
# "reply 'discount'" offer with no code change.
#
# Recommended: 25% off for the first year (match WINBACK_DISCOUNT_LABEL below).
#   _BASIC_MONTHLY  percent_off=25 duration=repeating duration_in_months=12
#   _PRO_MONTHLY    percent_off=25 duration=repeating duration_in_months=12
#   _BASIC_ANNUAL   percent_off=25 duration=once
#   _PRO_ANNUAL     percent_off=25 duration=once
# As with the promo coupons, restrict each to its specific product in Stripe so
# a monthly coupon can never land on an annual invoice if the vars get crossed.
STRIPE_COUPON_WINBACK_BASIC_MONTHLY=
STRIPE_COUPON_WINBACK_PRO_MONTHLY=
STRIPE_COUPON_WINBACK_BASIC_ANNUAL=
STRIPE_COUPON_WINBACK_PRO_ANNUAL=
# Human-readable label for the win-back discount, shown in the email copy and
# the /pricing welcome-back banner. MUST match the actual coupon value above.
WINBACK_DISCOUNT_LABEL="25% off your first year"

# --- Referral program (double-sided, "free month") ------------------------
# Master switch. Leave unset/0 to keep the whole program inert (no referral
# codes minted, no discounts applied, no rewards paid). Set to 1 to enable.
REFERRAL_PROGRAM_ENABLED=0
# Referee (the referred friend) discount coupons, created in the Stripe
# dashboard. Both should be duration=once:
#   _MONTHLY -> 100% off (first month free)
#   _ANNUAL  -> 10% off  (first year)
# Recommended hardening: in Stripe, restrict the 100%-off MONTHLY coupon to
# your monthly price IDs only ("Applies to -> specific products"). The app
# already keys the coupon to the chosen cadence, but this is belt-and-braces
# so a 100%-off can never land on an annual (full-year) invoice.
STRIPE_COUPON_REFERRAL_REFEREE_MONTHLY=
STRIPE_COUPON_REFERRAL_REFEREE_ANNUAL=
# Note: the REFERRER reward (one free month) is paid as a Stripe customer
# balance credit computed from the referrer's own plan (annual = 1/12 of the
# annual price), so it needs no coupon. Free months earned while the referrer
# has no active subscription are banked and auto-redeemed on their next signup.

# --- Creator Partner Program (invite-only, cash commissions) -------------
# Layered ON TOP of the referral plumbing above. A partner is still a normal
# user with a referral_code; partner_tier='creator' (set via
# scripts/grant-partner-pro.mjs) flips checkout to apply the audience coupon
# below instead of the standard referee coupon, and tells the webhook to
# accrue cash commissions into the partner_commissions ledger.
#
# Master switch. Leave unset/0 to keep the program inert: no creator flips
# are honored, no audience coupon is applied, no commissions accrue.
CREATOR_PARTNER_PROGRAM_ENABLED=0
# Audience-side discount applied at checkout when the inbound ?ref= resolves
# to a partner_tier='creator' user, AND attached automatically to every
# partner's per-creator promotion_code by scripts/grant-partner-pro.mts.
# Recommended Stripe coupon settings:
#   percent_off: 25
#   duration: repeating
#   duration_in_months: 3
#   applies_to.products: monthly price IDs only (belt-and-braces; the app
#                        already only applies this on monthly cadence)
# The script auto-creates one promotion_code per partner attached to this
# coupon (carrying metadata.partner_user_id so the webhook can back-attribute
# audience members who type the code at Stripe checkout). Per-partner
# overrides are written to users.partner_audience_coupon_id when grant-
# partner-pro.mts is run with --coupon-id; this env is the global fallback.
STRIPE_COUPON_PARTNER_AUDIENCE=

# Public app URL — used to build Stripe success/cancel/return URLs and the
# password-reset link sent in transactional email.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend transactional email (required for /forgot-password to deliver mail).
# RESEND_API_KEY: from https://resend.com/api-keys
# RESEND_FROM_EMAIL: must be on a domain verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL="ZeroGEX <noreply@your-domain.com>"

# ==============================================================================
# Product analytics (PostHog) — funnel instrumentation. ALL OPTIONAL: with no
# key set, analytics is a complete no-op (no events, no network, no behavior
# change). Set the key to turn it on.
# ==============================================================================
# Client-side project key (inlined into the browser bundle — this is a public,
# write-only PostHog project API key, safe to expose).
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog ingestion host. Defaults to PostHog US cloud if unset.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side key for webhook conversion events (trial_started,
# subscription_paid, subscription_cancelled). Falls back to
# NEXT_PUBLIC_POSTHOG_KEY when unset, so a single project key covers both
# client and server. Not prefixed NEXT_PUBLIC_ (kept server-side).
POSTHOG_KEY=

# ------------------------------------------------------------------------------
# X (Twitter) Ads pixel — paid-campaign tracking (see docs/twitter-ad-campaign.md).
# OPTIONAL: with no id set, the pixel is a complete no-op (no script, no network,
# no behavior change). Public value, inlined into the browser bundle, so it must
# be NEXT_PUBLIC_-prefixed. Get the id from X Ads Manager -> Tools -> Conversion
# tracking (a short id like "rdk7i").
NEXT_PUBLIC_TWITTER_PIXEL_ID=
#
# Server-side token for the X Conversions API (CAPI), which reports the
# trial_started / subscription_paid events from the Stripe webhook — more
# accurate than the browser pixel (survives ad-blockers / Safari). SECRET,
# server-side only, NOT NEXT_PUBLIC_. Generate it in X Ads Manager -> Tools ->
# Conversion tracking. No-op (CAPI disabled) when unset.
X_ADS_PIXEL_TOKEN=

# ==============================================================================
# Live Bulletin snapshot token — gates the public snapshot route the
# bulletin-tweet cron uses to screenshot the same GammaReportCard the
# paid /live-bulletin page renders.
#
# Route: /live-bulletin/snapshot/<symbol>?token=<value>
#   * Unset here: the route is OPEN — anyone can hit it and get a
#     fresh gamma card, which would defeat the /live-bulletin paywall.
#     Only leave unset in dev.
#   * Set here: the route 404s any request without the matching
#     ?token= param. The OA-side bulletin_tweet cron must have the
#     SAME value under BULLETIN_SNAPSHOT_TOKEN in its own .env so it
#     can pass ?token= through.
# ==============================================================================
BULLETIN_SNAPSHOT_TOKEN=

# ==============================================================================
# TradeWorkz follower email delivery worker
# ==============================================================================
# `make tradeworkz-notify` and its systemd timer
# (zerogex-web-tradeworkz-notify.timer, every minute) drain queued email
# notifications from tw_notifications_log via two internal endpoints on
# the OA API:
#     GET  /api/tradeworkz/internal/queued-notifications
#     POST /api/tradeworkz/internal/mark-notification
# Both are behind the SIGNALS scope so the worker uses the SAME shared
# bearer key that the /api/* BFF proxy already carries — no new scope,
# no new machine credential.
#
# TRADEWORKZ_INTERNAL_API: base URL of the OA API, reachable from the
#     web tier. In the single-box deploy the two services co-locate and
#     127.0.0.1:8000 is correct. If you split them onto different hosts,
#     set this to the internal-network hostname (never the public API
#     domain — this endpoint carries follower email addresses).
# Default: http://127.0.0.1:8000
TRADEWORKZ_INTERNAL_API=http://127.0.0.1:8000
